{
  "name": "NutriTrace Diary Add - MCP",
  "description": "Add a food to NutriTrace diary. Requires food_name (searches by name). Optional: date (defaults today), quantity (1), meal (breakfast/lunch/dinner/snacks). Returns confirmation with calories added.",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nutritrace-diary-add",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "name": "Webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://100.111.123.105:3002/diary/add",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "food_name",
              "value": "={{ $json.body.food_name }}"
            },
            {
              "name": "quantity",
              "value": "={{ $json.body.quantity || 1 }}"
            },
            {
              "name": "meal",
              "value": "={{ $json.body.meal || \"lunch\" }}"
            },
            {
              "name": "date",
              "value": "={{ $json.body.date || $now.format(\"yyyy-MM-dd\") }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        200,
        0
      ],
      "name": "HTTP Request"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}
