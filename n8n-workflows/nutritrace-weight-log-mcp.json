{
  "name": "NutriTrace Weight Log - MCP",
  "description": "Log a weight entry to NutriTrace. Requires weight (number, in kg). Optional: date (defaults today), unit (kg/lb), notes.",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nutritrace-weight-log",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "name": "Webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://100.111.123.105:3002/weight/log",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "weight",
              "value": "={{ $json.body.weight }}"
            },
            {
              "name": "date",
              "value": "={{ $json.body.date || $now.format(\"yyyy-MM-dd\") }}"
            },
            {
              "name": "unit",
              "value": "={{ $json.body.unit || \"kg\" }}"
            },
            {
              "name": "notes",
              "value": "={{ $json.body.notes || \"\" }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        200,
        0
      ],
      "name": "HTTP Request"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}
