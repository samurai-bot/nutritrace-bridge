      "webhookId": "f6b190e5-f355-4859-9b83-c05bcb5744e3"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://100.111.123.105:3002/diary/add",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "food_name",
              "value": "={{ $json.body.food_name }}"
            },
            {
              "name": "quantity",
              "value": "={{ $json.body.quantity || 1 }}"
            },
            {
              "name": "meal",
              "value": "={{ $json.body.meal || \"lunch\" }}"
            },
            {
              "name": "date",
              "value": "={{ $json.body.date || $now.format(\"yyyy-MM-dd\") }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
