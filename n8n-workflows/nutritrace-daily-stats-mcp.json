{
  "name": "NutriTrace Daily Stats - MCP",
  "description": "Get daily nutrition summary for a specific date. Returns total calories, protein, carbs, fat, fiber, sodium, water intake, and per-meal breakdown. Use date=YYYY-MM-DD.",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "nutritrace-daily-stats",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "name": "Webhook"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://100.111.123.105:3002/stats/daily",
        "options": {},
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "date",
              "value": "={{$json.query.date || $now.format(\"yyyy-MM-dd\")}}"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        200,
        0
      ],
      "name": "HTTP Request"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}
