{
  "name": "NutriTrace Diary Get - MCP",
  "description": "Get the full diary entry for a specific date. Returns all logged food items with quantities and meal slots, body stats (weight, measurements), water intake, and notes. Use date=YYYY-MM-DD.",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "nutritrace-diary-get",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "name": "Webhook"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://100.111.123.105:3002/diary",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "date",
              "value": "={{ $json.query.date }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        200,
        0
      ],
      "name": "HTTP Request"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}