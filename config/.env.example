# Host-side bind mount paths — set to wherever you store Docker data
DATA_DB_PATH=/your/host/path/db
DATA_UPLOADS_PATH=/your/host/path/uploads

# Required if using user management — use a long random string, keep it secret
# Generate one: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
# Or mount it as a Docker/Swarm secret:
# JWT_SECRET_FILE=/run/secrets/nutritrace_jwt_secret

# Optional — At-rest encryption key for OIDC client secrets and wearable
# OAuth tokens (Fitbit, Garmin, Withings refresh tokens). Defaults to a key
# derived from JWT_SECRET, which means rotating JWT_SECRET also invalidates
# every encrypted secret. Set TOKEN_ENC_KEY explicitly if you want to rotate
# session tokens independently of stored secrets.
# Generate one: openssl rand -base64 48
# TOKEN_ENC_KEY=change-me-to-a-long-random-key
# TOKEN_ENC_KEY_FILE=/run/secrets/nutritrace_token_enc_key

# Optional — Lockout recovery token
# Required to use the "Disable user management" recovery option on the login page
# Without this, the recovery endpoint is disabled for safety
# RECOVERY_TOKEN=my-secret-recovery-phrase
# RECOVERY_TOKEN_FILE=/run/secrets/nutritrace_recovery_token

# Optional — Mount the app at a path other than root (for reverse-proxy setups)
# Example: BASE_URL=/nutritrace will serve the app at https://example.com/nutritrace/
# Default unset = served at root path. See DEPLOY.md for full instructions.
# BASE_URL=/nutritrace

# Optional — Allow auth cookies over plain HTTP (no TLS)
# Default unset means auth cookies are marked Secure, so browsers only return
# them over HTTPS. If your deployment runs on plain HTTP (LAN, dev box, no
# reverse proxy with TLS), login appears to succeed but every subsequent
# request 401s because the browser silently drops the cookie. Set this to 1
# to opt out. Cookies will then travel in cleartext, so ONLY use this on a
# trusted network. For internet-facing deployments, put TLS in front instead
# (Caddy, nginx with Let's Encrypt, Cloudflare Tunnel, etc.).
# INSECURE_COOKIES=1

# ─── Local Open Food Facts mirror (Issue #22) ──────────────────────────────
# When OFF_LOCAL_DB is set, barcode and food-name lookups try a local OFF
# mirror before reaching the public api.openfoodfacts.org. Useful for
# air-gapped self-hosters, strict-egress environments, and resilience when
# the OFF API is down.
#
# File formats supported (auto-detected by extension):
#   .parquet  — Hugging Face Parquet dump (default since rc.39, the
#               maintained option after OFF retired their native DuckDB
#               snapshot). DuckDB queries it via read_parquet().
#   .duckdb   — Legacy native DuckDB file (pre-rc.39 setups still work).
#
# Setup:
#   1. Uncomment the OFF mirror volume mount in docker-compose.yml. IMPORTANT:
#      the mount points at a parent DIRECTORY (e.g. ./off-mirror:/data/off-mirror),
#      not the file itself. Docker auto-creates missing single-file bind-mount
#      sources as directories on the host, which breaks the atomic-swap rename
#      during refresh with EISDIR. The file lives inside the mounted directory.
#   2. Set OFF_LOCAL_DB below to the in-container path to the file
#      (e.g. /data/off-mirror/off.parquet). NutriTrace downloads the initial
#      snapshot (~7-8 GB) automatically on first boot if the file is missing.
#   3. (Optional) Set OFF_LOCAL_ONLY=1 to refuse any fallback to the remote
#      OFF API. True air-gap mode: lookups for products not in the mirror
#      return "not found" instead of querying the public API.
#   4. docker compose up -d
#
# Auto-refresh: open Settings → Connected Services → Open Food Facts (admin
# only) to pick a schedule (Off / Daily / Weekly / Monthly, default Weekly)
# and trigger an immediate Refresh Now. Refreshes are full re-downloads with
# atomic swap; no container restart needed. See DEPLOY.md → "Local Open Food
# Facts mirror" for the full guide.
#
# OFF_LOCAL_DB=/data/off-mirror/off.parquet
# OFF_LOCAL_ONLY=1
# Optional — pin the download source. Defaults to the maintained Hugging Face
# Parquet dump. To use a legacy / self-hosted DuckDB file instead, set this to
# a URL ending in .duckdb and use a .duckdb extension on OFF_LOCAL_DB.
# OFF_LOCAL_URL=https://huggingface.co/datasets/openfoodfacts/product-database/resolve/main/food.parquet?download=true

# Optional — Log level (error | warn | info | debug)
# Default: info — logs requests, warnings, and errors
# Set to 'debug' for verbose wellness sync output (Fitbit, Withings, Garmin, Health Connect)
# LOG_LEVEL=info

# Optional — SMTP email (for password reset & user invites)
# If set, these override whatever is configured in the Settings UI AND lock those fields for all users
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465 (SSL), false for STARTTLS
# SMTP_USER=you@example.com
# SMTP_PASS=your-password
# SMTP_FROM=NutriTrace <noreply@example.com>
# SMTP_PASS_FILE=/run/secrets/nutritrace_smtp_pass

# Optional — AI Assistant (shared key for all users)
# If set, AI calls are proxied through the server (key never reaches the browser)
# and the provider/model/key fields are locked in Settings for all users.
# Only the cloud providers below are server-proxied. The "OpenAI Compatible"
# provider (Ollama, LM Studio, DeepSeek, Groq, etc.) runs entirely client-side
# — the browser talks to your endpoint directly — and is configured per-user in
# Settings, not via env vars.
# AI_PROVIDER=claude        # claude | openai | gemini
# AI_API_KEY=sk-ant-...
# AI_API_KEY_FILE=/run/secrets/nutritrace_ai_api_key
# AI_MODEL=claude-haiku-4-5-20251001   # optional, defaults to provider's fast model
# AI_ENABLED=true           # optional, auto-enables the AI Assistant for all users

# Optional — OIDC Single Sign-On (declared in env instead of the Settings UI)
#
# Single-provider shorthand — `OIDC_*` is an alias for `OIDC_PROVIDER_1_*`:
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=nutritrace
# OIDC_CLIENT_SECRET=...
# OIDC_DISPLAY_NAME=Authentik
# OIDC_REDIRECT_URIS=https://nutritrace.example.com/api/auth/oidc/callback/1     # comma-separated for multi
# OIDC_SCOPE=openid profile email
# OIDC_TOKEN_AUTH_METHOD=client_secret_post   # or client_secret_basic | none
# OIDC_ADMIN_GROUP_CLAIM=groups
# OIDC_ADMIN_GROUP_VALUE=NutriTraceAdmins
# OIDC_AUTO_LINK=1                            # link verified-email to existing users (default 1)
# OIDC_AUTO_REGISTER=0                        # blanket signup on first SSO login (default 0)
# OIDC_IS_ACTIVE=1
#
# Multi-provider — use the numbered prefix:
# OIDC_PROVIDER_2_ISSUER=https://other-idp.example.com
# OIDC_PROVIDER_2_CLIENT_ID=...
# OIDC_PROVIDER_2_CLIENT_SECRET=...
# OIDC_PROVIDER_2_DISPLAY_NAME=Keycloak
#
# Env-defined providers show with a lock badge in Settings → User Management →
# OIDC providers and are read-only. Edit via .env / docker-compose / k8s
# secrets — UI mutations on env-defined providers are refused server-side.
